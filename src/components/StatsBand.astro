---

<section
  class="bg-sand-deep/40 px-6 md:px-16 py-16 border-y border-basalt/10 tapa-pattern"
>
  <div class="max-w-7xl mx-auto grid grid-cols-2 md:grid-cols-4 gap-y-10">
    <div
      class="reveal flex flex-col items-center md:border-r border-ochre/20 px-4"
    >
      <span class="font-headline text-5xl md:text-6xl text-ochre leading-none"
        >133<sup class="italic text-4xl"> sq mi</sup></span
      >
      <span
        class="font-label text-[10px] tracking-[0.22em] uppercase mt-3 text-basalt/65 font-semibold text-center"
        >Island Area</span
      >
    </div>
    <div
      class="reveal flex flex-col items-center md:border-r border-ochre/20 px-4"
      style="transition-delay: 0.1s;"
    >
      <span class="font-headline text-5xl md:text-6xl text-ochre leading-none"
        >2,579<sup class="italic text-4xl"> ft</sup></span
      >
      <span
        class="font-label text-[10px] tracking-[0.22em] uppercase mt-3 text-basalt/65 font-semibold text-center"
        >Highest Peak · Nahna Laud</span
      >
    </div>
    <div
      class="reveal flex flex-col items-center md:border-r border-ochre/20 px-4"
      style="transition-delay: 0.2s;"
    >
      <span class="font-headline text-5xl md:text-6xl text-ochre leading-none"
        >40<sup class="italic text-4xl">+</sup></span
      >
      <span
        class="font-label text-[10px] tracking-[0.22em] uppercase mt-3 text-basalt/65 font-semibold text-center"
        >Waterfalls</span
      >
    </div>
    <div
      class="reveal flex flex-col items-center px-4"
      style="transition-delay: 0.3s;"
    >
      <span class="font-headline text-4xl md:text-5xl text-ochre leading-none tracking-tight"
        >UNESCO</span
      >
      <span
        class="font-label text-[10px] tracking-[0.22em] uppercase mt-3 text-basalt/65 font-semibold text-center"
        >Nan Madol · World Heritage Site</span
      >
    </div>
  </div>
</section>
