---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import StatusStrip from '../components/StatusStrip.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Places to Stay in Pohnpei — The Garden Island of Micronesia"
  description="Where to stay in Pohnpei. Small hotels in Kolonia, guesthouses, and Airbnbs — no chain resorts, that's the point."
>
  <Nav />
  <StatusStrip />

  <main class="pt-[116px]">
    <section class="py-28 md:py-36 px-6 md:px-24 bg-sand">
      <div class="max-w-3xl mx-auto">
        <span
          class="font-label text-ochre tracking-[0.3em] uppercase text-[11px] font-semibold mb-8 block"
        >
          Plan Your Visit
        </span>
        <h1
          class="font-headline text-basalt text-4xl md:text-5xl lg:text-6xl leading-[1.02] tracking-tight mb-10"
        >
          Places to <em class="italic text-ochre">stay</em>.
        </h1>

        <div class="space-y-8 font-body text-basalt/75 text-[16px] leading-relaxed">
          <p>
            Pohnpei doesn't have chain resorts — that's the point. What it has
            are small hotels in Kolonia, a handful of guesthouses closer to
            the water, and a few Airbnb listings that come and go. Book early.
            Options are limited, and the good ones fill up fast.
          </p>
        </div>

        <!-- Search placeholder -->
        <div class="mt-12 bg-sand-bright border border-basalt/10 p-8 md:p-10">
          <h2 class="font-headline text-2xl text-basalt mb-2">Find a stay</h2>
          <p class="font-body text-basalt/50 text-sm mb-6">
            An accommodation finder is coming soon.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <input
              type="text"
              disabled
              placeholder="Search hotels, guesthouses, Airbnbs..."
              class="flex-grow bg-transparent border-b-2 border-basalt/15 px-0 py-3 font-body text-base placeholder:text-basalt/25 cursor-not-allowed"
            />
            <button
              disabled
              class="bg-basalt/20 text-basalt/40 px-8 py-4 font-label uppercase tracking-[0.14em] text-xs font-semibold cursor-not-allowed whitespace-nowrap"
            >
              Search
            </button>
          </div>
        </div>

        <div class="mt-12 space-y-8 font-body text-basalt/75 text-[16px] leading-relaxed">
          <div>
            <h2 class="font-headline text-2xl text-basalt mb-4">What to Expect</h2>
            <ul class="space-y-2 list-none">
              <li class="flex items-start gap-3">
                <span class="text-ochre mt-1">→</span>
                <span><strong class="text-basalt">Hotels in Kolonia</strong> — a few mid-range options within walking distance of shops and restaurants. Air conditioning, hot water, Wi-Fi.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-ochre mt-1">→</span>
                <span><strong class="text-basalt">Guesthouses</strong> — simpler, often family-run. Closer to the coast or in quieter parts of the island. More character, fewer amenities.</span>
              </li>
              <li class="flex items-start gap-3">
                <span class="text-ochre mt-1">→</span>
                <span><strong class="text-basalt">Airbnb</strong> — availability varies. Some listings are apartments in Kolonia, others are houses further out. Check recent reviews.</span>
              </li>
            </ul>
          </div>

          <p class="italic text-basalt/55">
            This page will grow into a full accommodation directory with
            listings, photos, and availability. For now, the best approach is
            to ask a local tour operator — they know what's open and what's
            worth it.
          </p>
        </div>

        <div class="mt-16 pt-10 border-t border-basalt/10">
          <a
            href="/#dispatch"
            class="bg-ochre text-white px-8 py-4 font-label uppercase tracking-[0.14em] text-xs font-semibold hover:bg-ochre-deep active:scale-95 transition-all inline-block"
          >
            Join the Dispatch for Updates
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
