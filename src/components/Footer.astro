---

---

<footer class="bg-sand relative overflow-hidden">
  <div class="h-3 tapa-divider opacity-40"></div>
  <div
    class="max-w-7xl mx-auto py-16 px-6 md:px-12 grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-14"
  >
    <div class="md:col-span-1">
      <div class="flex items-center gap-4 mb-6">
        <div
          class="w-11 h-11 bg-basalt flex items-center justify-center text-sand font-headline text-2xl font-semibold"
        >
          P
        </div>
        <div>
          <div class="font-headline text-xl text-basalt">Pohnpei Island</div>
          <div
            class="font-label text-[9px] tracking-[0.28em] uppercase text-basalt/60"
          >
            The Garden Island · Micronesia
          </div>
        </div>
      </div>
      <p class="font-headline italic text-xl text-basalt/80 leading-snug max-w-[22ch]">
        Built from Pohnpei — for everyone who wants to find the Garden Island.
      </p>
    </div>

    <div>
      <h4
        class="font-label text-[10px] tracking-[0.2em] uppercase mb-5 text-ochre font-bold"
      >
        The Island
      </h4>
      <ul class="flex flex-col gap-3 font-body text-[14px] text-basalt/75">
        <li>
          <a class="hover:text-ochre transition-colors" href="/#about"
            >About Pohnpei</a
          >
        </li>
        <li>
          <a class="hover:text-ochre transition-colors" href="/#culture"
            >The Culture</a
          >
        </li>
        <li>
          <a class="hover:text-ochre transition-colors" href="/#nan-madol"
            >History &amp; Nan Madol</a
          >
        </li>
        <li>
          <a class="hover:text-ochre transition-colors" href="/#atolls"
            >Outer Atolls</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h4
        class="font-label text-[10px] tracking-[0.2em] uppercase mb-5 text-ochre font-bold"
      >
        Plan Your Visit
      </h4>
      <ul class="flex flex-col gap-3 font-body text-[14px] text-basalt/75">
        <li>
          <a class="hover:text-ochre transition-colors" href="/getting-here"
            >Getting Here</a
          >
        </li>
        <li>
          <a class="hover:text-ochre transition-colors" href="/places-to-stay"
            >Places to Stay</a
          >
        </li>
        <li>
          <a class="hover:text-ochre transition-colors" href="/plan-your-trip"
            >Plan Your Trip</a
          >
        </li>
        <li>
          <a class="hover:text-ochre transition-colors" href="/travel-info"
            >Travel Info</a
          >
        </li>
      </ul>
    </div>

    <div>
      <h4
        class="font-label text-[10px] tracking-[0.2em] uppercase mb-5 text-ochre font-bold"
      >
        Stay Connected
      </h4>
      <p class="font-body text-[14px] text-basalt/75 leading-relaxed mb-5">
        A resource for visitors to Pohnpei State, FSM.
      </p>
      <div class="flex gap-3">
        <a
          href="#"
          aria-label="Instagram"
          class="w-10 h-10 bg-basalt text-sand grid place-items-center font-label text-[11px] font-bold tracking-wide hover:bg-ochre transition-all"
          >IG</a
        >
        <a
          href="#"
          aria-label="Facebook"
          class="w-10 h-10 bg-basalt text-sand grid place-items-center font-label text-[11px] font-bold tracking-wide hover:bg-ochre transition-all"
          >FB</a
        >
        <a
          href="#"
          aria-label="YouTube"
          class="w-10 h-10 bg-basalt text-sand grid place-items-center font-label text-[11px] font-bold tracking-wide hover:bg-ochre transition-all"
          >YT</a
        >
      </div>
    </div>
  </div>

  <div
    class="border-t border-basalt/10 py-6 px-6 md:px-12 max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-center gap-3 font-label text-[10px] tracking-[0.18em] uppercase text-basalt/50 font-medium"
  >
    <span>© 2026 PohnpeiIsland.com</span>
    <span>Pohnpei State · Federated States of Micronesia</span>
  </div>
</footer>
