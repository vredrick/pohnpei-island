---
const items = [
  'Kaselehlie',
  'The Garden Island',
  'Nan Madol',
  'Sokehs Ridge',
  'Kepirohi Falls',
  'Pakin Atoll',
  'Sakau',
  'Liduduhniap',
  'Upon a Stone Altar',
  'Ahnd Atoll',
  'Tiahk en Pohnpei',
];
---

<div class="bg-basalt py-6 overflow-hidden border-y border-sand/10">
  <div class="marquee-track">
    {
      [...items, ...items].map((text) => (
        <>
          <span class="font-headline italic text-sand/80 text-2xl md:text-3xl flex items-center gap-6 px-6 whitespace-nowrap">
            {text}
          </span>
          <span class="font-headline italic text-ochre text-2xl px-6">✦</span>
        </>
      ))
    }
  </div>
</div>
