---

---

<section class="hero-section relative flex flex-col md:flex-row overflow-hidden">
  <div class="hero-panel flex-1 relative overflow-hidden bg-basalt">
    <img
      class="hero-zoom w-full h-full object-cover absolute inset-0"
      src="https://res.cloudinary.com/doruy2kdr/image/upload/f_auto,q_auto,c_fill,g_auto,w_1600,h_1100/hero-left-matnas.jpg"
      alt="Pohnpei rainforest waterfall at Matnas"
      loading="eager"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(180deg, rgba(10,8,6,0.35) 0%, rgba(10,8,6,0.55) 100%);"
    >
    </div>
  </div>
  <div class="hero-seam"></div>
  <div class="hero-panel flex-1 relative overflow-hidden bg-basalt">
    <img
      class="hero-zoom w-full h-full object-cover absolute inset-0"
      src="https://res.cloudinary.com/doruy2kdr/image/upload/f_auto,q_auto,c_fill,g_auto,w_1600,h_1100/hero-right-manta-road-pass.jpg"
      alt="Manta Road Pass — Pohnpei reef and lagoon"
      loading="eager"
    />
    <div
      class="absolute inset-0"
      style="background: linear-gradient(180deg, rgba(10,8,6,0.35) 0%, rgba(10,8,6,0.55) 100%);"
    >
    </div>
  </div>

  <!-- Central vignette -->
  <div
    class="absolute inset-0 pointer-events-none"
    style="background: radial-gradient(ellipse 75% 65% at 50% 52%, rgba(10,8,6,0.55) 0%, rgba(10,8,6,0.15) 75%, transparent 100%);"
  >
  </div>

  <div
    class="hero-content absolute inset-0 flex flex-col items-center justify-center px-5 text-center pointer-events-none"
  >
    <span
      class="anim-fadeDown font-label text-white tracking-[0.3em] uppercase text-[10px] sm:text-xs mb-5 sm:mb-6 flex items-center"
      style="animation-delay: 0.15s; text-shadow: 0 2px 16px rgba(0,0,0,0.6);"
    >
      <span class="inline-block align-middle w-6 sm:w-10 h-px bg-white/80 mr-3"
      ></span>
      Kaselehlie — Welcome to Pohnpei
      <span class="inline-block align-middle w-6 sm:w-10 h-px bg-white/80 ml-3"
      ></span>
    </span>
    <h1
      class="anim-fadeUp font-headline text-white max-w-5xl leading-[1] sm:leading-[0.98] text-[32px] sm:text-5xl md:text-6xl lg:text-7xl xl:text-[84px] tracking-tight"
      style="animation-delay: 0.3s; text-shadow: 0 4px 32px rgba(0,0,0,0.85), 0 2px 10px rgba(0,0,0,0.7);"
    >
      <span class="block">The island the Pacific</span>
      <em class="italic text-white block mt-1">kept for itself.</em>
    </h1>
    <p
      class="anim-fadeUp font-body text-white/95 text-sm sm:text-base md:text-lg max-w-xl md:max-w-2xl mt-6 sm:mt-8 leading-relaxed px-2"
      style="animation-delay: 0.65s; text-shadow: 0 2px 18px rgba(0,0,0,0.8);"
    >
      Rainforest that runs to the reef. Waterfalls you hike to alone. A
      culture that hasn't been packaged for anyone. This is Pohnpei — the
      Garden Island.
    </p>
    <div
      class="anim-fadeUp mt-8 sm:mt-10 flex flex-col sm:flex-row gap-3 sm:gap-4 pointer-events-auto w-full sm:w-auto px-4 sm:px-0 max-w-md sm:max-w-none"
      style="animation-delay: 0.9s;"
    >
      <a
        href="#about"
        class="bg-ochre text-white px-6 sm:px-8 py-4 font-label uppercase tracking-[0.14em] text-[11px] sm:text-xs font-semibold hover:bg-ochre-deep transition-all active:scale-95 text-center"
      >
        See What's Here
      </a>
      <a
        href="/plan-your-trip"
        class="border border-white/80 bg-black/20 backdrop-blur-sm text-white px-6 sm:px-8 py-4 font-label uppercase tracking-[0.14em] text-[11px] sm:text-xs font-semibold hover:bg-white hover:text-basalt transition-all active:scale-95 text-center"
      >
        Start Planning
      </a>
    </div>
  </div>
</section>
