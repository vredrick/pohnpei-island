---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import StatusStrip from '../components/StatusStrip.astro';
import Hero from '../components/Hero.astro';
import IntroEditorial from '../components/IntroEditorial.astro';
import StatsBand from '../components/StatsBand.astro';
import ChaptersGrid from '../components/ChaptersGrid.astro';
import NanMadolFeature from '../components/NanMadolFeature.astro';
import StartPlanning from '../components/StartPlanning.astro';
import DispatchForm from '../components/DispatchForm.astro';
import MarqueeTicker from '../components/MarqueeTicker.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
  <Nav />
  <StatusStrip />

  <main id="top" class="pt-[116px]">
    <Hero />
    <IntroEditorial />
    <StatsBand />
    <ChaptersGrid />
    <NanMadolFeature />
    <StartPlanning />
    <DispatchForm />
    <MarqueeTicker />
  </main>

  <Footer />
</BaseLayout>
